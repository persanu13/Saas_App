// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider     = "prisma-client"
  output       = "../generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

enum UserType {
  APP_ADMIN
  CUSTOMER
  PROFESSIONAL
}

enum OrgRole {
  OWNER
  MANAGER
  STAFF
}

model Account {
  id                Int     @id @default(autoincrement())
  userId            Int     @map("user_id")
  type              String
  provider          String
  providerAccountId String  @map("provider_account_id")
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([provider, providerAccountId, userId])
  @@map("accounts")
}

model Session {
  id           Int      @id @default(autoincrement())
  sessionToken String   @unique @map("session_token")
  userId       Int      @map("user_id")
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("sessions")
}

model VerificationToken {
  id        Int                   @id @default(autoincrement())
  token     String                @unique
  userId    Int                   @map("user_id")
  type      VerificationTokenType
  expiresAt DateTime              @map("expires_at")
  usedAt    DateTime?             @map("used_at")
  createdAt DateTime              @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("verification_tokens")
}

enum VerificationTokenType {
  EMAIL
  PHONE
  PASSWORD_RESET
}

model User {
  id            Int       @id @default(autoincrement())
  name          String?
  email         String
  emailVerified DateTime? @map("email_verified")
  image         String?
  phone         String?

  hashPassword String?  @map("hash_password")
  type         UserType

  memberships OrganizationMember[]

  lastActiveOrganizationId Int?          @map("last_active_organization_id")
  lastActiveOrganization   Organization? @relation(fields: [lastActiveOrganizationId], references: [id])

  accounts Account[]
  sessions Session[]

  VerificationTokens VerificationToken[]

  isActive           Boolean       @default(true) @map("is_active")
  createdAt          DateTime      @default(now()) @map("created_at")
  updatedAt          DateTime      @updatedAt @map("updated_at")
  bookedAppointments Appointment[] @relation("BookedAppointments")
  clientAppointments Appointment[] @relation("ClientAppointments")

  @@unique([email, type], name: "email_type")
  @@map("users")
}

model Organization {
  id   Int     @id @default(autoincrement())
  name String
  slug String? @unique

  members  OrganizationMember[]
  services Service[] // toate serviciile organizatiei

  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  users     User[]

  @@map("organizations")
}

enum DayOfWeek {
  MONDAY
  TUESDAY
  WEDNESDAY
  THURSDAY
  FRIDAY
  SATURDAY
  SUNDAY
}

model OrganizationMember {
  id Int @id @default(autoincrement())

  userId         Int          @map("user_id")
  organizationId Int          @map("organization_id")
  role           OrgRole
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  weeklySchedules WeeklySchedule[]
  services        MemberService[]
  appointments    Appointment[]
  blockedTimes    BlockedTime[]

  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, organizationId])
  @@index([organizationId])
  @@index([userId])
  @@map("organization_members")
}

model WeeklySchedule {
  id       Int                @id @default(autoincrement())
  memberId Int                @map("member_id")
  member   OrganizationMember @relation(fields: [memberId], references: [id], onDelete: Cascade)

  validFrom  DateTime  @map("valid_from")
  validUntil DateTime? @map("valid_until")
  isActive   Boolean   @default(true) @map("is_active")

  slots ScheduleSlot[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([memberId])
  @@map("weekly_schedules")
}

model ScheduleSlot {
  id         Int            @id @default(autoincrement())
  scheduleId Int            @map("schedule_id")
  schedule   WeeklySchedule @relation(fields: [scheduleId], references: [id], onDelete: Cascade)

  day      DayOfWeek
  startMin Int       @map("start_min")
  endMin   Int       @map("end_min")

  @@index([scheduleId, day])
  @@map("schedule_slots")
}

model Service {
  id             Int          @id @default(autoincrement())
  organizationId Int          @map("organization_id")
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  name        String
  description String?
  durationMin Int     @map("duration_min")
  price       Float?

  members      MemberService[]
  appointments AppointmentService[]

  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([organizationId])
  @@map("services")
}

model MemberService {
  id        Int                @id @default(autoincrement())
  memberId  Int                @map("member_id")
  member    OrganizationMember @relation(fields: [memberId], references: [id], onDelete: Cascade)
  serviceId Int                @map("service_id")
  service   Service            @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@unique([memberId, serviceId])
  @@index([memberId])
  @@index([serviceId])
  @@map("member_services")
}

model Appointment {
  id Int @id @default(autoincrement())

  memberId Int                @map("member_id")
  member   OrganizationMember @relation(fields: [memberId], references: [id], onDelete: Cascade)

  bookedById Int  @map("booked_by_id")
  bookedBy   User @relation("BookedAppointments", fields: [bookedById], references: [id])

  clientId Int?  @map("client_id")
  client   User? @relation("ClientAppointments", fields: [clientId], references: [id])

  clientName  String? @map("client_name")
  clientPhone String? @map("client_phone")

  services AppointmentService[]

  date     DateTime
  startMin Int      @map("start_min")
  endMin   Int      @map("end_min")

  notes String?

  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([memberId])
  @@index([clientId])
  @@index([memberId, date])
  @@map("appointments")
}

model AppointmentService {
  id            Int         @id @default(autoincrement())
  appointmentId Int         @map("appointment_id")
  appointment   Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  serviceId     Int         @map("service_id")
  service       Service     @relation(fields: [serviceId], references: [id])

  @@unique([appointmentId, serviceId])
  @@index([appointmentId])
  @@index([serviceId])
  @@map("appointment_services")
}

model BlockedTime {
  id Int @id @default(autoincrement())

  memberId Int                @map("member_id")
  member   OrganizationMember @relation(fields: [memberId], references: [id], onDelete: Cascade)

  date     DateTime
  startMin Int      @map("start_min")
  endMin   Int      @map("end_min")

  title  String
  reason String?

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([memberId, date])
  @@map("blocked_times")
}
