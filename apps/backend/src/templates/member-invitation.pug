doctype html
html(lang="en")
  head
    meta(charset="UTF-8")
    meta(name="viewport" content="width=device-width, initial-scale=1.0")
    title Invitation to join #{organizationName}
    style.
      body {
        margin: 0;
        padding: 0;
        background-color: #f4f4f5;
        font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;
      }
      .container {
        max-width: 480px;
        margin: 40px auto;
        background-color: #ffffff;
        border-radius: 8px;
        overflow: hidden;
        border: 1px solid #e4e4e7;
      }
      .header {
        background-color: #18181b;
        padding: 24px 32px;
      }
      .header h1 {
        color: #ffffff;
        font-size: 18px;
        margin: 0;
        font-weight: 600;
      }
      .content {
        padding: 32px;
      }
      .content p {
        color: #3f3f46;
        font-size: 15px;
        line-height: 1.6;
        margin: 0 0 16px;
      }
      .org-name {
        font-weight: 600;
        color: #18181b;
      }
      .role-badge {
        display: inline-block;
        background-color: #f4f4f5;
        color: #18181b;
        font-size: 13px;
        font-weight: 600;
        padding: 4px 10px;
        border-radius: 4px;
        margin: 4px 0 20px;
      }
      .button {
        display: inline-block;
        background-color: #18181b;
        color: #ffffff !important;
        text-decoration: none;
        font-size: 14px;
        font-weight: 600;
        padding: 12px 24px;
        border-radius: 6px;
        margin: 8px 0 24px;
      }
      .fallback {
        color: #71717a;
        font-size: 13px;
        word-break: break-all;
        margin-top: 8px;
      }
      .expires {
        color: #a1a1aa;
        font-size: 13px;
        margin-top: 24px;
        border-top: 1px solid #e4e4e7;
        padding-top: 16px;
      }
      .footer {
        padding: 24px 32px;
        text-align: center;
      }
      .footer p {
        color: #a1a1aa;
        font-size: 12px;
        margin: 0;
      }

  body
    .container
      .header
        h1 Trimly
      .content
        p Hi,
        p
          span.org-name= invitedByName
          |  has invited you to join
          |
          span.org-name= organizationName
          |  on Trimly.
        div
          span.role-badge= role

        p Click the button below to accept the invitation and get started.

        a.button(href=invitationLink) Accept invitation

        p.fallback
          | If the button doesn't work, copy and paste this link into your browser:
          br
          = invitationLink

        p.expires
          | This invitation will expire on #{expiresAt}. If you weren't expecting this invitation, you can safely ignore this email.

      .footer
        p © #{currentYear} Trimly. All rights reserved.
